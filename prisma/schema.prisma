generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id        String   @id @default(cuid())
  name      String
  phone     String
  service   String
  date      String
  time      String
  duration  Int      @default(30)
  status    String   @default("active")
  ip        String   @default("")
  createdAt DateTime @default(now())
}
